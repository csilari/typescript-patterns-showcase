{
    "compilerOptions": {
      "target": "ESNext",
      "module": "CommonJS",
      "strict": true,                 // MUST be true for the patterns to work
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist",
      "rootDir": "./src"
    },
    "include": ["src/**/*", "tests/**/*"]
  }